RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=Resume Gate <noreply@example.com>

# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@host/neondb?sslmode=require

# Auth (better-auth)
BETTER_AUTH_SECRET=replace_with_32_char_random_string
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
ADMIN_EMAIL=you@example.com

# Microlink.io (optional — free tier works without key)
MICROLINK_API_KEY=

# Beehiiv (newsletter)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Anthropic (admin "Generate with AI" for bookmarks)
ANTHROPIC_API_KEY=

# Content Repo (for the content)
CONTENT_REPO_TOKEN=